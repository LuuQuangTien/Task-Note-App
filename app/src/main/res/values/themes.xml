<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - forced dark -->
    <style name="Base.Theme.TickTickAndroid" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/bottomNavBackground</item>
    </style>

    <style name="Theme.TickTickAndroid" parent="Base.Theme.TickTickAndroid" />

    <style name="Theme.TickTick.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.TickTickAndroid</item>
    </style>
</resources>